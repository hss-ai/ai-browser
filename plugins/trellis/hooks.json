{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/trellis.sh brief-gate"
          },
          {
            "type": "command",
            "command": "./hooks/trellis.sh build-gate"
          },
          {
            "type": "command",
            "command": "./hooks/trellis.sh agent-token-mint"
          }
        ],
        "matcher": "Agent"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/trellis.sh swarm-write"
          },
          {
            "type": "command",
            "command": "./hooks/trellis.sh verify-gate"
          },
          {
            "type": "command",
            "command": "./hooks/trellis.sh confirm-gate"
          }
        ],
        "matcher": "Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/trellis.sh swarm-write"
          },
          {
            "type": "command",
            "command": "./hooks/trellis.sh verify-gate"
          },
          {
            "type": "command",
            "command": "./hooks/trellis.sh confirm-gate"
          }
        ],
        "matcher": "Edit"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/trellis.sh swarm-guard"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/trellis.sh dispatch-stop"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/trellis.sh agent-token-refresh"
          },
          {
            "type": "command",
            "command": "./hooks/trellis.sh plan-complete-gate"
          }
        ],
        "matcher": "Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/trellis.sh agent-token-refresh"
          },
          {
            "type": "command",
            "command": "./hooks/trellis.sh plan-complete-gate"
          }
        ],
        "matcher": "Edit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/trellis.sh session-save"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/trellis.sh store-validate"
          }
        ],
        "matcher": "mcp__odd-flow__memory_store"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/trellis.sh sync-validate"
          }
        ],
        "matcher": "mcp__odd-flow__coordination_sync"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/trellis.sh code-quality"
          },
          {
            "type": "command",
            "command": "./hooks/trellis.sh security-quality"
          },
          {
            "type": "command",
            "command": "./hooks/trellis.sh brief-quality"
          },
          {
            "type": "command",
            "command": "./hooks/trellis.sh outcome-quality"
          }
        ],
        "matcher": "Write"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/trellis.sh code-quality"
          },
          {
            "type": "command",
            "command": "./hooks/trellis.sh security-quality"
          }
        ],
        "matcher": "Edit"
      }
    ]
  }
}
