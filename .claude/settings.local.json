{
  "hooks": {
    "PreToolUse": [
      {
        "_trellis": true,
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh brief-gate",
            "timeout": 5,
            "statusMessage": "Trellis brief gate..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh build-gate",
            "timeout": 5,
            "statusMessage": "Trellis build gate..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh agent-token-mint",
            "timeout": 5,
            "statusMessage": "Trellis agent token..."
          }
        ],
        "matcher": "Agent"
      },
      {
        "_trellis": true,
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh swarm-write",
            "timeout": 5,
            "statusMessage": "Trellis swarm write gate..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh verify-gate",
            "timeout": 5,
            "statusMessage": "Trellis verification gate..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh confirm-gate",
            "timeout": 5,
            "statusMessage": "Trellis confirm gate..."
          }
        ],
        "matcher": "Write"
      },
      {
        "_trellis": true,
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh swarm-write",
            "timeout": 5,
            "statusMessage": "Trellis swarm write gate..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh verify-gate",
            "timeout": 5,
            "statusMessage": "Trellis verification gate..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh confirm-gate",
            "timeout": 5,
            "statusMessage": "Trellis confirm gate..."
          }
        ],
        "matcher": "Edit"
      }
    ],
    "UserPromptSubmit": [
      {
        "_trellis": true,
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh swarm-guard",
            "timeout": 5,
            "statusMessage": "Trellis swarm guard..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "_trellis": true,
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh dispatch-stop",
            "timeout": 5,
            "statusMessage": "Trellis dispatch stop..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "_trellis": true,
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh agent-token-refresh",
            "timeout": 5,
            "statusMessage": "Trellis agent token refresh..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh plan-complete-gate",
            "timeout": 5,
            "statusMessage": "Trellis plan complete gate..."
          }
        ],
        "matcher": "Write"
      },
      {
        "_trellis": true,
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh agent-token-refresh",
            "timeout": 5,
            "statusMessage": "Trellis agent token refresh..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh plan-complete-gate",
            "timeout": 5,
            "statusMessage": "Trellis plan complete gate..."
          }
        ],
        "matcher": "Edit"
      },
      {
        "_trellis": true,
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh session-save",
            "timeout": 10,
            "statusMessage": "Trellis session save..."
          }
        ],
        "matcher": "Bash"
      },
      {
        "_trellis": true,
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh store-validate",
            "timeout": 5,
            "statusMessage": "Trellis store validate..."
          }
        ],
        "matcher": "mcp__odd-flow__memory_store"
      },
      {
        "_trellis": true,
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh sync-validate",
            "timeout": 5,
            "statusMessage": "Trellis sync validate..."
          }
        ],
        "matcher": "mcp__odd-flow__coordination_sync"
      },
      {
        "_trellis": true,
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh code-quality",
            "timeout": 5,
            "statusMessage": "Trellis code quality..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh security-quality",
            "timeout": 5,
            "statusMessage": "Trellis security quality..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh brief-quality",
            "timeout": 5,
            "statusMessage": "Trellis brief quality..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh outcome-quality",
            "timeout": 5,
            "statusMessage": "Trellis outcome quality..."
          }
        ],
        "matcher": "Write"
      },
      {
        "_trellis": true,
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh code-quality",
            "timeout": 5,
            "statusMessage": "Trellis code quality..."
          },
          {
            "type": "command",
            "command": ".claude/hooks/trellis.sh security-quality",
            "timeout": 5,
            "statusMessage": "Trellis security quality..."
          }
        ],
        "matcher": "Edit"
      }
    ]
  }
}
