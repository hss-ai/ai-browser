{
  "name": "ai-browser",
  "version": "1.3.3",
  "description": "Multi-AI Split Screen Browser",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:pack": "npx @electron/packager . AI-Browser --platform=win32 --arch=x64 --out=release --overwrite",
    "dist:win": "npx electron-builder --win --x64",
    "dist:mac": "npx electron-builder --mac --x64 --arm64",
    "dist:linux": "npx electron-builder --linux --x64",
    "dist:all": "npx electron-builder --win --mac --linux --x64 --arm64"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "@electron/packager": "^20.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.aibrowser.app",
    "productName": "AI-Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": null
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64"]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": null
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Utility",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": null
    }
  },
  "dependencies": {
    "openspec": "^0.0.0"
  }
}
